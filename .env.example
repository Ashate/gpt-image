# ============================================================
#  ImageGen AI — Docker Compose 环境变量
#  复制此文件为 .env 并填写你的真实配置
# ============================================================

# OpenAI API Key（必填）
OPENAI_API_KEY=sk-your-openai-api-key-here

# JWT 密钥（必填，建议用随机长字符串）
JWT_SECRET=change-this-to-a-long-random-secret-string
# MyAQL用户(必填)
DB_USER=root

# MySQL 密码（必填）
DB_PASSWORD=your_strong_mysql_password

# 数据库名（可选，默认 image_gen_db）
DB_NAME=image_gen_db

# 前端访问地址（用于 CORS，改成你的域名或 IP）
FRONTEND_URL=http://localhost

# 应用对外端口（默认 80）
APP_PORT=80
